# Example compose environment values for Valhalla
# These are written to /etc/valhalla/compose.env by the installer.
# The default internal domain is valhalla, which is recommended to keep unless you have a reason to change it.

VALHALLA_HOST_IP=192.168.1.50
VALHALLA_TAILSCALE_IP=100.127.100.50
VALHALLA_DOMAIN=valhalla
HOMEPAGE_ALLOWED_HOSTS=homepage.valhalla,192.168.1.50:3000,100.127.100.50:3000
